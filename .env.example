# Copy to .env for local (non-Docker) runs. docker-compose sets these itself.
# Comments sit on their own lines: trailing inline comments make the file
# unsourceable in zsh (`. ./.env`).
DATABASE_URL=postgres://foreman:foreman@localhost:5432/foreman
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# === Celery / Redis (M2) ===
# Broker + result backend default to REDIS_URL.
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Run tasks inline (tests / no-broker local runs).
# CELERY_TASK_ALWAYS_EAGER=true

# How often beat polls the outbox.
# OUTBOX_POLL_SECONDS=1.0

# === M3 reliability: retries, backoff, dead-letter, lease ===
# Defaults shown.

# How often beat re-dispatches due retries.
# RECOVER_POLL_SECONDS=5.0

# Attempts, including the first, before dead-letter.
# JOB_MAX_ATTEMPTS=3

# Backoff base; ceiling doubles per attempt.
# JOB_RETRY_BASE_SECONDS=2

# Backoff cap.
# JOB_RETRY_MAX_SECONDS=300

# Worker lease TTL while PROCESSING.
# JOB_LEASE_SECONDS=120

# Re-dispatch visibility window for due retries.
# JOB_REQUEUE_VISIBILITY_SECONDS=60

# === M3 worker durability: at-least-once delivery + crash recovery ===
# Defaults shown.

# Acknowledge after the task finishes, not before.
# CELERY_TASK_ACKS_LATE=true

# Re-queue if the worker is killed mid-task.
# CELERY_TASK_REJECT_ON_WORKER_LOST=true

# At most one unacked task per worker.
# CELERY_WORKER_PREFETCH_MULTIPLIER=1

# Broker redelivery backstop, in seconds.
# CELERY_VISIBILITY_TIMEOUT=3600

# === M4 observability ===
# json for structured JSON logs (default), console for human-readable dev logs.
# DJANGO_LOG_FORMAT=json

# === M4 realtime: Django Channels ===
# The WebSocket channel layer defaults to REDIS_URL.
# Override to isolate WS pub/sub from the broker.
# CHANNELS_REDIS_URL=redis://localhost:6379/0

# === Production (M5) ===
# Set these when deploying behind HTTPS.
# The dev defaults above are insecure.
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=<a long random secret, 50+ chars>
# DJANGO_ALLOWED_HOSTS=foreman.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://foreman.example.com

# Redirect HTTP to HTTPS.
# Safe only because SECURE_PROXY_SSL_HEADER is set in settings.
# DJANGO_SECURE_SSL_REDIRECT=true

# Add the Secure flag to session and CSRF cookies.
# DJANGO_SECURE_COOKIES=true

# HSTS duration in seconds (31536000 = 1 year).
# Also enables includeSubDomains + preload in settings.
# DJANGO_SECURE_HSTS_SECONDS=31536000

# DATABASE_URL / REDIS_URL come from the platform's managed Postgres + Redis.

# === Deployment: Railway (operator tooling, never read by the app) ===
# Account token for `terraform apply` / `make configure`
# (RAILWAY_TOKEN_KIND=account); CI holds a narrower project token.
# RAILWAY_TOKEN=REPLACE_ME
